# --- GLOBAL SETTINGS for all hosts (*) ---

Host *
    IdentityAgent ~/.bitwarden-ssh-agent.sock  # (1)!
    # User admin  (2)

# --- HOST-SPECIFIC SETTINGS ---

Host Pi-Server
    HostName pi-server.internal
    User admin
    IdentityFile ~/.ssh/pi-server.pub
    IdentitiesOnly yes  # (3)!

Host ASUS-Router
    HostName asusrouter.internal
    User Admin
    IdentityFile ~/.ssh/asusrouter.pub
    IdentitiesOnly yes

Host ZimaOS-NAS
    HostName storage-server-2.internal
    User admin
    IdentityFile ~/.ssh/storage-server.pub
    IdentitiesOnly yes

Host Debian-VM
    HostName debian-vm.internal
    User server-admin
    IdentityFile ~/.ssh/debian-vm.pub
    IdentitiesOnly yes

Host Creality-K1C
    HostName k1c-a71e.internal
    User root
    IdentityFile ~/.ssh/k1c-a71e.pub
    IdentitiesOnly no

Host Pi-Zero
    HostName pi-zero.internal
    User admin
    IdentityFile ~/.ssh/pi-zero.pub
    IdentitiesOnly yes

Host Gitea
    HostName storage-server.internal
    Port 222
    User git
    IdentityFile ~/.ssh/gitea.pub
    IdentitiesOnly yes

Host Gitlab
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/gitlab.pub
    IdentitiesOnly yes

Host GitHub
    HostName github.com
    User git
    IdentityFile ~/.ssh/github.pub
    IdentitiesOnly yes